:- module main.
main :- klicio:klicio([stdout(S)]), o(S).
o(abnormal).
/* Standard order of terms: @< @=< @> @>= (with integers, numeric order).
 * Ref: KLIC.info "Comparison and Hashing". */
o(normal(St)) :- lt(1,2,R1), le(2,2,R2), gt(3,2,R3), ge(2,2,R4), St=[putt([R1,R2,R3,R4]), nl].
lt(X,Y,R) :- X @<  Y | R=yes.
le(X,Y,R) :- X @=< Y | R=yes.
gt(X,Y,R) :- X @>  Y | R=yes.
ge(X,Y,R) :- X @>= Y | R=yes.
