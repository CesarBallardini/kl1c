:- module main.
main :- klicio:klicio([stdout(S)]), o(S).
o(abnormal).
/* compare/3 (guard) -> integer <0/=0/>0.  Ref: KLIC.info "Comparison and Hashing".
 * With integers for determinism (atom order is by internal number). */
o(normal(St)) :- c(1,2,R1), c(2,2,R2), c(3,2,R3), St=[putt([R1,R2,R3]), nl].
c(X,Y,R) :- compare(X,Y,C), C  < 0 | R=lt.
c(X,Y,R) :- compare(X,Y,C), C =:= 0 | R=eq.
c(X,Y,R) :- compare(X,Y,C), C  > 0 | R=gt.
