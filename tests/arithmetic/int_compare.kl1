:- module main.
main :- klicio:klicio([stdout(S)]), o(S).
o(abnormal).
/* Integer comparison guards: > >= =:= =\= =< <.  Ref: KLIC.info "Integer Comp". */
o(normal(St)) :- gt(3,2,R1),ge(2,2,R2),eq(5,5,R3),ne(5,4,R4),le(2,2,R5),lt(1,2,R6),
    St=[putt([R1,R2,R3,R4,R5,R6]), nl].
gt(X,Y,R) :- X  > Y | R=yes.
ge(X,Y,R) :- X >= Y | R=yes.
eq(X,Y,R) :- X =:= Y | R=yes.
ne(X,Y,R) :- X =\= Y | R=yes.
le(X,Y,R) :- X =< Y | R=yes.
lt(X,Y,R) :- X  < Y | R=yes.
